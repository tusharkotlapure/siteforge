# SiteForge Server — Environment Variables
# Copy this file to server/.env for local development

# Server port (Render sets this automatically in production)
PORT=3001

# Set to "production" on Render (auto-set via render.yaml)
NODE_ENV=development

# Optional: Anthropic API key for real AI content generation
# Without this, the app uses smart demo content (fully functional)
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: Override allowed CORS origins (comma-separated)
# Leave blank in production — Express serves frontend from same origin
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
